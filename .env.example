# ===========================
# Variables de Entorno — DEMAND-24
# ===========================
# Copiar a .env y completar con valores reales.
# NUNCA versionar el archivo .env en Git.

# ---------- Supabase ----------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---------- Base de datos (conexión directa PostgreSQL vía Supabase) ----------
DATABASE_URL=postgresql://postgres:your_password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---------- JWT (Supabase Auth maneja esto internamente) ----------
JWT_SECRET=your_supabase_jwt_secret

# ---------- MLflow ----------
MLFLOW_TRACKING_URI=http://localhost:5000

# ---------- Configuración del Piloto ----------
PILOT_SKU_IDS=101,102,103,104,105
MIN_WEEKS_HISTORY=12
MAPE_LOW_CONFIDENCE_THRESHOLD=25.0
ETL_SCHEDULE_CRON=0 5 * * 1

# ---------- App ----------
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ---------- Frontend ----------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
